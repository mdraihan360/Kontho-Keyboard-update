<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⌨️"
            android:textSize="64sp"
            android:gravity="center"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KonthoBoard AI"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#4F9DFF"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="বাংলা + English AI কীবোর্ড"
            android:textSize="14sp"
            android:textColor="#9999CC"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp" />

        <!-- Step 1 -->
        <LinearLayout
            android:id="@+id/card_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E38"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ধাপ ১ — কীবোর্ড সক্রিয় করুন"
                android:textColor="#E8E8FF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Settings › System › Language &amp; Input › On-screen Keyboard এ গিয়ে KonthoBoard AI চালু করুন।"
                android:textColor="#9999CC"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_enable"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="কীবোর্ড সক্রিয় করুন"
                android:backgroundTint="#4F9DFF"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_step1_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ সক্রিয় হয়েছে"
                android:textColor="#00E676"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Step 2 -->
        <LinearLayout
            android:id="@+id/card_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E38"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ধাপ ২ — ডিফল্ট কীবোর্ড সেট করুন"
                android:textColor="#E8E8FF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KonthoBoard AI কে ডিফল্ট ইনপুট মেথড হিসেবে নির্বাচন করুন।"
                android:textColor="#9999CC"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_default"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="ডিফল্ট হিসেবে সেট করুন"
                android:backgroundTint="#4F9DFF"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_step2_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ ডিফল্ট সেট হয়েছে"
                android:textColor="#00E676"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Settings Button -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⚙️ সেটিংস খুলুন"
            android:backgroundTint="#252538"
            android:textColor="#9999CC"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
