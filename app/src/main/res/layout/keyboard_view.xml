<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/dark_kb_bg">

    <!-- Suggestion Bar -->
    <LinearLayout
        android:id="@+id/suggestion_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@color/dark_sugg_bg">

        <TextView
            android:id="@+id/suggestion_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/dark_sugg_text"
            android:textSize="13sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/dark_key_border" />

        <TextView
            android:id="@+id/suggestion_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/dark_sugg_text"
            android:textSize="13sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/dark_key_border" />

        <TextView
            android:id="@+id/suggestion_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/dark_sugg_text"
            android:textSize="13sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Toolbar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:scrollbars="none"
        android:background="#0D0D1A">

        <LinearLayout
            android:id="@+id/toolbar_layout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/tb_emoji"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Emoji"
                android:src="@android:drawable/ic_menu_agenda" />

            <ImageButton
                android:id="@+id/tb_voice"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voice"
                android:src="@drawable/ic_mic" />

            <ImageButton
                android:id="@+id/tb_clipboard"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clipboard"
                android:src="@android:drawable/ic_menu_edit" />

            <ImageButton
                android:id="@+id/tb_settings"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:src="@android:drawable/ic_menu_preferences" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Main Key Rows Container -->
    <LinearLayout
        android:id="@+id/keys_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

</LinearLayout>
